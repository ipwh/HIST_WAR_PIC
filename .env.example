# ============================================================
#  香港抗戰歷史圖像生成器 — 環境變數設定
#  複製此檔案為 .env 並填入你的 API Key
# ============================================================

# AI 後端選擇：stability / replicate / huggingface
# Hugging Face 有免費額度，推薦先用這個
AI_PROVIDER=huggingface

# Stability AI API Key
# 前往 https://platform.stability.ai/ 註冊並取得
STABILITY_API_KEY=sk-your-stability-api-key-here

# Replicate API Key
# 前往 https://replicate.com/ 註冊並取得
REPLICATE_API_KEY=r8-your-replicate-api-key-here

# Hugging Face API Key（免費！）
# 前往 https://huggingface.co/settings/tokens 建立 Read token
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# 伺服器連接埠（預設 3000）
PORT=3000

# 公開網址（用於 QR Code 掃碼下載）
# 留空則自動偵測本機 IP，手機需與電腦在同一 WiFi 網絡
# 手動設定範例：PUBLIC_BASE_URL=http://192.168.1.100:3000
PUBLIC_BASE_URL=
